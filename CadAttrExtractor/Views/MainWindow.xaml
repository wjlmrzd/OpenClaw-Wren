<Window x:Class="CadAttrExtractor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CadAttrExtractor.Views"
        xmlns:conv="clr-namespace:CadAttrExtractor.Converters"
        mc:Ignorable="d"
        Title="图纸目录提取器"
        Width="480"
        Height="620"
        MinWidth="400"
        MinHeight="500"
        WindowStyle="ToolWindow"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource PanelBackground}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar / Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource ControlBackground}"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="图纸目录提取器"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"/>
                    <TextBlock Text="提取 · 排序 · 表格 · 导出"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Theme Toggle -->
                <ToggleButton Grid.Column="1"
                              x:Name="ThemeToggle"
                              IsChecked="False"
                              Click="ThemeToggle_Click"
                              ToolTip="切换深色/浅色主题"
                              Width="36"
                              Height="28"
                              Margin="4,0"
                              Cursor="Hand"
                              VerticalAlignment="Center"
                              Style="{DynamicResource SecondaryButtonStyle}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="border"
                                    Background="{DynamicResource ControlBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="icon"
                                               Text="&#x263E;"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="icon" Property="Text" Value="&#x2600;"/>
                                    <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- Settings Button -->
                <Button Grid.Column="2"
                        Content="&#x2699;"
                        FontSize="16"
                        ToolTip="设置"
                        Width="36"
                        Height="28"
                        Padding="0"
                        Click="SettingsButton_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Tab Control with 5 Tabs -->
        <TabControl Grid.Row="1"
                    x:Name="MainTabControl"
                    Background="Transparent"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Foreground="{DynamicResource PrimaryText}"
                    Padding="8,0">

            <!-- Tab 1: Extract -->
            <TabItem Header="提取">
                <local:ExtractView DataContext="{Binding}"/>
            </TabItem>

            <!-- Tab 2: Preview -->
            <TabItem Header="预览">
                <local:PreviewView DataContext="{Binding}"/>
            </TabItem>

            <!-- Tab 3: Table -->
            <TabItem Header="表格">
                <local:TableView DataContext="{Binding}"/>
            </TabItem>

            <!-- Tab 4: Export -->
            <TabItem Header="导出">
                <local:ExportView DataContext="{Binding}"/>
            </TabItem>

            <!-- Tab 5: Settings -->
            <TabItem Header="设置">
                <local:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlBackground}"
                Padding="12,6"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="{DynamicResource SmallFontSize}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Items.Count, StringFormat=已提取 {0} 项}"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="{DynamicResource SmallFontSize}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ProgressBar Value="{Binding ProgressValue}"
                                 Maximum="100"
                                 Width="80"
                                 Height="4"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 Background="{DynamicResource InputBackground}"
                                 Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource ControlBackground}"
                Padding="12,8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="v1.0.0 · WrenTools"
                           Foreground="{DynamicResource DisabledText}"
                           FontSize="{DynamicResource SmallFontSize}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="关于"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="AboutButton_Click"
                        Padding="12,4"
                        Margin="0,0,4,0"/>

                <Button Grid.Column="2"
                        Content="关闭"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="CloseButton_Click"
                        Padding="12,4"/>
            </Grid>
        </Border>
    </Grid>
</Window>
