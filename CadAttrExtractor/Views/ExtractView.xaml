<UserControl x:Class="CadAttrExtractor.Views.ExtractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:CadAttrExtractor.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="440"
             Background="{DynamicResource PanelBackground}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Header -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="提取属性"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"/>
                    <TextBlock Text="从图块中提取属性信息并按坐标排序"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Filter Section -->
                <GroupBox Header="过滤条件" Margin="0,0,0,8">
                    <StackPanel>
                        <Label Content="图块名称 (支持 * 和 ? 通配符)"/>
                        <TextBox Text="{Binding BlockNamePattern, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="留空或输入 * 匹配所有图块"/>

                        <Label Content="属性标签 (可选)"/>
                        <TextBox Text="{Binding AttributeTag, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="留空提取所有属性"/>

                        <Label Content="图层名称 (可选)"/>
                        <TextBox Text="{Binding LayerName, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="留空匹配所有图层"/>
                    </StackPanel>
                </GroupBox>

                <!-- Options Section -->
                <GroupBox Header="提取选项" Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox Content="包含匿名块"
                                  IsChecked="{Binding IncludeAnonymousBlocks}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,4"/>

                        <CheckBox Content="提取时显示进度"
                                  IsChecked="{Binding ShowProgress}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,4"/>

                        <CheckBox Content="提取前确认"
                                  IsChecked="{Binding ConfirmBeforeExtract}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,4"/>
                    </StackPanel>
                </GroupBox>

                <!-- Extraction Scope Section -->
                <GroupBox Header="提取范围" Margin="0,0,0,8">
                    <StackPanel>
                        <RadioButton x:Name="RadioCurrentSpace"
                                     Content="当前空间 (模型/布局)"
                                     IsChecked="True"
                                     Foreground="{DynamicResource PrimaryText}"
                                     Margin="0,4"
                                     GroupName="ExtractScope"/>
                        <RadioButton x:Name="RadioSelection"
                                     Content="仅选择集"
                                     Foreground="{DynamicResource PrimaryText}"
                                     Margin="0,4"
                                     GroupName="ExtractScope"/>
                    </StackPanel>
                </GroupBox>

                <!-- Progress Section -->
                <Border Background="{DynamicResource ControlBackground}"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="{DynamicResource SmallFontSize}"/>
                        <ProgressBar Value="{Binding ProgressValue}"
                                     Maximum="100"
                                     Height="6"
                                     Margin="0,8,0,0"
                                     Foreground="{DynamicResource PrimaryBrush}"
                                     Background="{DynamicResource InputBackground}"/>
                    </StackPanel>
                </Border>

                <!-- Item Count -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="已提取项目"
                                   Foreground="{DynamicResource SecondaryText}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Items.Count, StringFormat={}{0} 项}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{DynamicResource LargeFontSize}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Extract Button -->
        <Button Grid.Row="1"
                Content="提取属性"
                Style="{DynamicResource PrimaryButtonStyle}"
                Command="{Binding ExtractCommand}"
                IsEnabled="{Binding IsExtracting, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                HorizontalAlignment="Stretch"
                Height="40"
                FontSize="{DynamicResource LargeFontSize}"
                Margin="0,8,0,0"/>

    </Grid>
</UserControl>
