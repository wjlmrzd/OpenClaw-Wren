<UserControl x:Class="CadAttrExtractor.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:CadAttrExtractor.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="440"
             Background="{DynamicResource PanelBackground}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="导出"
                       FontSize="{DynamicResource LargeFontSize}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"/>
            <TextBlock Text="将提取结果导出为 Excel、Word 或 CSV 文件"
                       FontSize="{DynamicResource SmallFontSize}"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Template Selection -->
                <GroupBox Header="模板文件" Margin="0,0,0,8">
                    <StackPanel>
                        <Label Content="Excel 模板路径 (可选)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ExcelTemplatePath}"
                                     IsReadOnly="True"
                                     ToolTip="留空使用默认模板"/>
                            <Button Grid.Column="1"
                                    Content="浏览"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    Margin="4,4,0,0"
                                    Click="BrowseExcelTemplate_Click"/>
                        </Grid>

                        <Label Content="Word 模板路径 (可选)" Margin="0,8,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding WordTemplatePath}"
                                     IsReadOnly="True"
                                     ToolTip="留空使用默认模板"/>
                            <Button Grid.Column="1"
                                    Content="浏览"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    Margin="4,4,0,0"
                                    Click="BrowseWordTemplate_Click"/>
                        </Grid>

                        <CheckBox Content="使用模板文件格式化输出"
                                  IsChecked="{Binding UseTemplateFormatting}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,8,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Attribute Mapping -->
                <GroupBox Header="属性映射" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="图名标签"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding TitleTag, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="属性标签名称"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="图号标签"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding IndexTag, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="属性标签名称"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="版本标签"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding VersionTag, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="属性标签名称"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="日期标签"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding DateTag, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="属性标签名称"/>
                    </Grid>
                </GroupBox>

                <!-- CSV Options -->
                <GroupBox Header="CSV 导出选项" Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox Content="导出 CSV 格式"
                                  IsChecked="{Binding ExportCSV}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,4"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,0"
                                    IsEnabled="{Binding ExportCSV}">
                            <Label Content="编码:" VerticalAlignment="Center"/>
                            <ComboBox SelectedItem="{Binding CSVEncoding}"
                                      Width="120"
                                      IsEnabled="{Binding ExportCSV}">
                                <ComboBoxItem Content="UTF-8"/>
                                <ComboBoxItem Content="GB2312"/>
                                <ComboBoxItem Content="UTF-8 with BOM"/>
                            </ComboBox>
                            <Label Content="分隔符:" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <ComboBox SelectedItem="{Binding CSVSeparator}"
                                      Width="80"
                                      IsEnabled="{Binding ExportCSV}">
                                <ComboBoxItem Content=","/>
                                <ComboBoxItem Content=";"/>
                                <ComboBoxItem Content="Tab"/>
                            </ComboBox>
                        </StackPanel>

                        <CheckBox Content="包含表头行"
                                  IsChecked="{Binding CSVIncludeHeader}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,8,0,0"
                                  IsEnabled="{Binding ExportCSV}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Export Preview -->
                <GroupBox Header="导出预览" Margin="0,0,0,8">
                    <Border Background="{DynamicResource ControlBackground}"
                            CornerRadius="4"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="已提取项目"
                                       Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Items.Count, StringFormat={}{0} 项}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="输出格式"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="Excel (.xlsx) / Word (.docx) / CSV"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="{DynamicResource SmallFontSize}"
                                       Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="兼容性"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="WPS + Office 2010+"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       FontSize="{DynamicResource SmallFontSize}"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </Border>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Export Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="导出 Excel"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Command="{Binding ExportExcelCommand}"
                    Width="130"
                    Height="40"
                    FontSize="{DynamicResource LargeFontSize}"/>
            <Button Content="导出 Word"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Command="{Binding ExportWordCommand}"
                    Width="130"
                    Height="40"
                    FontSize="{DynamicResource LargeFontSize}"/>
            <Button Content="导出 CSV"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Command="{Binding ExportCSVCommand}"
                    Width="100"
                    Height="40"
                    FontSize="{DynamicResource LargeFontSize}"
                    IsEnabled="{Binding ExportCSV}"/>
        </StackPanel>

        <!-- Clear Button -->
        <Button Grid.Row="3"
                Content="清空数据"
                Style="{DynamicResource SecondaryButtonStyle}"
                Command="{Binding ClearCommand}"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Padding="24,6"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="4"
                     Value="{Binding ProgressValue}"
                     Maximum="100"
                     Height="6"
                     Margin="0,8,0,0"
                     Foreground="{DynamicResource PrimaryBrush}"
                     Background="{DynamicResource ControlBackground}"
                     Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibilityConverter}}"/>

    </Grid>
</UserControl>
