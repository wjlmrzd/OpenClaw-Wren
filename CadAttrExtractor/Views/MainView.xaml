<UserControl x:Class="CadAttrExtractor.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CadAttrExtractor.Views"
             xmlns:vm="clr-namespace:CadAttrExtractor.ViewModels"
             xmlns:conv="clr-namespace:CadAttrExtractor.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="480"
             Background="{DynamicResource PanelBackground}">

    <UserControl.Resources>
        <!-- Converters -->
        <conv:SortModeConverter x:Key="SortModeConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource DisabledText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource FocusBorder}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource DisabledText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="0,4"/>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource PanelBackground}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource FocusBorder}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="图纸目录提取器"
                       FontSize="{DynamicResource HeaderFontSize}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"/>
            <TextBlock Text="提取块属性、坐标排序、生成表格、导出Excel/Word"
                       FontSize="{DynamicResource SmallFontSize}"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="2" 
                    Background="Transparent" 
                    BorderBrush="{DynamicResource BorderBrush}"
                    Foreground="{DynamicResource PrimaryText}">

            <!-- Extract Tab -->
            <TabItem Header="提取">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <!-- Filter Section -->
                        <GroupBox Header="过滤条件" Margin="0,8">
                            <StackPanel>
                                <Label Content="图块名称 (支持*通配符)"/>
                                <TextBox Text="{Binding BlockNamePattern, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="属性标签"/>
                                <TextBox Text="{Binding AttributeTag, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="图层 (可选)"/>
                                <TextBox Text="{Binding LayerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Options Section -->
                        <GroupBox Header="选项" Margin="0,8">
                            <StackPanel>
                                <CheckBox Content="包含匿名块"
                                          IsChecked="{Binding IncludeAnonymousBlocks}"
                                          Foreground="{DynamicResource PrimaryText}"
                                          Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Extract Button -->
                        <Button Content="提取属性"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ExtractCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,12"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Preview Tab -->
            <TabItem Header="预览">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sort Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                        <Label Content="排序方式:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding SortModes}"
                                  SelectedItem="{Binding SelectedSortMode}"
                                  Width="200"
                                  Margin="8,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource SortModeConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="应用排序"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SortCommand}"/>
                    </StackPanel>

                    <!-- Items DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Items}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              Margin="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding DisplayIndex}" Width="40"/>
                            <DataGridTextColumn Header="图块名称" Binding="{Binding BlockName}" Width="120"/>
                            <DataGridTextColumn Header="图纸名称" Binding="{Binding DrawingTitle}" Width="*"/>
                            <DataGridTextColumn Header="图号" Binding="{Binding DrawingIndex}" Width="60"/>
                            <DataGridTextColumn Header="坐标" Binding="{Binding PositionText}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Table Tab -->
            <TabItem Header="表格">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <GroupBox Header="表格设置" Margin="0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                                    <Label Content="行高"/>
                                    <TextBox Text="{Binding RowHeight}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                                    <Label Content="列宽"/>
                                    <TextBox Text="{Binding ColumnWidth}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                                    <Label Content="文字样式"/>
                                    <ComboBox ItemsSource="{Binding TextStyles}"
                                              SelectedItem="{Binding SelectedTextStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                                    <Label Content="文字高度"/>
                                    <TextBox Text="{Binding TextHeight}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="4">
                                    <Label Content="表头文本"/>
                                    <TextBox Text="{Binding TableHeaderText}"/>
                                </StackPanel>
                            </Grid>
                        </GroupPanel>

                        <!-- Insertion Point -->
                        <GroupBox Header="插入点" Margin="0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding InsertionPointText}"
                                           Foreground="{DynamicResource PrimaryText}"
                                           Margin="0,4"/>
                                <Button Content="拾取插入点"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding PickPointCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupPanel>

                        <!-- Generate Button -->
                        <Button Content="生成表格"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding GenerateTableCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,12"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Export Tab -->
            <TabItem Header="导出">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <GroupBox Header="导出设置" Margin="0,8">
                            <StackPanel>
                                <Label Content="属性映射"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="图名标签"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TitleTag}"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="图号标签"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding IndexTag}"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="版本标签"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VersionTag}"/>

                                    <Label Grid.Row="3" Grid.Column="0" Content="日期标签"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DateTag}"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Export Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16">
                            <Button Content="导出 Excel"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ExportExcelCommand}"
                                    Width="120"/>
                            <Button Content="导出 Word"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ExportWordCommand}"
                                    Width="120"/>
                        </StackPanel>

                        <!-- Clear Button -->
                        <Button Content="清空数据"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ClearCommand}"
                                HorizontalAlignment="Center"
                                Margin="0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" 
                Background="{DynamicResource ControlBackground}" 
                CornerRadius="4"
                Padding="8,6"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryText}"
                           VerticalAlignment="Center"/>

                <ProgressBar Grid.Column="1"
                             Value="{Binding ProgressValue}"
                             Width="100"
                             Height="8"
                             Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- Bottom Actions -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="设置"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="SettingsButton_Click"/>
            <Button Content="关于"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="AboutButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
