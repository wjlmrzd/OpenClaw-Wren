<Window x:Class="CadAttrExtractor.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="设置 - 图纸目录提取器"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PanelBackground}">

    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource FocusBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Extract Settings -->
                <GroupBox Header="提取设置">
                    <StackPanel>
                        <Label Content="坐标排序容差"/>
                        <TextBox x:Name="ToleranceTextBox" Text="1.0"/>

                        <CheckBox x:Name="IncludeAnonymousCheckBox" Content="包含匿名块" IsChecked="True"/>

                        <Label Content="标题正则模式 (每行一个)"/>
                        <TextBox x:Name="RegexPatternsTextBox"
                                 AcceptsReturn="True"
                                 Height="100"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </GroupBox>

                <!-- Table Settings -->
                <GroupBox Header="表格设置">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                            <Label Content="行高"/>
                            <TextBox x:Name="RowHeightTextBox" Text="8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                            <Label Content="列宽"/>
                            <TextBox x:Name="ColumnWidthTextBox" Text="50"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                            <Label Content="文字高度"/>
                            <TextBox x:Name="TextHeightTextBox" Text="3"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                            <Label Content="每页行数"/>
                            <TextBox x:Name="RowsPerPageTextBox" Text="30"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="4">
                            <CheckBox x:Name="AutoPaginateCheckBox" Content="自动分页" IsChecked="True"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Export Settings -->
                <GroupBox Header="导出设置">
                    <StackPanel>
                        <Label Content="属性标签映射"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                                <Label Content="图名标签"/>
                                <TextBox x:Name="TitleTagTextBox"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                                <Label Content="图号标签"/>
                                <TextBox x:Name="IndexTagTextBox"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                                <Label Content="版本标签"/>
                                <TextBox x:Name="VersionTagTextBox"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                                <Label Content="日期标签"/>
                                <TextBox x:Name="DateTagTextBox"/>
                            </StackPanel>
                        </Grid>

                        <Label Content="Excel 模板路径"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ExcelTemplateTextBox" Grid.Column="0"/>
                            <Button Grid.Column="1" Content="浏览..." 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="4,4,0,4"
                                    Click="BrowseExcelTemplate_Click"/>
                        </Grid>

                        <Label Content="Word 模板路径"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="WordTemplateTextBox" Grid.Column="0"/>
                            <Button Grid.Column="1" Content="浏览..." 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="4,4,0,4"
                                    Click="BrowseWordTemplate_Click"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- UI Settings -->
                <GroupBox Header="界面设置">
                    <StackPanel>
                        <CheckBox x:Name="AutoShowPaletteCheckBox" Content="启动时自动显示面板" IsChecked="True"/>
                        <CheckBox x:Name="ConfirmExtractCheckBox" Content="提取前确认" IsChecked="True"/>
                        <CheckBox x:Name="RememberSortModeCheckBox" Content="记住排序模式" IsChecked="True"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="保存" 
                    Style="{StaticResource ButtonStyle}"
                    Click="SaveButton_Click"/>
            <Button Content="取消" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click"/>
            <Button Content="重置默认" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ResetButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
