<UserControl x:Class="CadAttrExtractor.Views.TableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:CadAttrExtractor.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="440"
             Background="{DynamicResource PanelBackground}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="表格生成"
                       FontSize="{DynamicResource LargeFontSize}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"/>
            <TextBlock Text="配置表格参数后在 CAD 图纸中生成目录表格"
                       FontSize="{DynamicResource SmallFontSize}"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Settings -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Basic Settings -->
                <GroupBox Header="表格尺寸" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                            <Label Content="行高"/>
                            <TextBox Text="{Binding RowHeight, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="单位：绘图单位"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                            <Label Content="文字高度"/>
                            <TextBox Text="{Binding TextHeight, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="单位：绘图单位"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                            <Label Content="序号列宽"/>
                            <TextBox Text="{Binding IndexColumnWidth}"
                                     ToolTip="单位：绘图单位"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                            <Label Content="表头文本"/>
                            <TextBox Text="{Binding TableHeaderText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="表格标题"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Column Widths -->
                <GroupBox Header="列宽设置" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                            <Label Content="图号列 (A)"/>
                            <TextBox Text="{Binding ColumnWidthA}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                            <Label Content="图名列 (B)"/>
                            <TextBox Text="{Binding ColumnWidthB}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                            <Label Content="版本列 (C)"/>
                            <TextBox Text="{Binding ColumnWidthC}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                            <Label Content="日期列 (D)"/>
                            <TextBox Text="{Binding ColumnWidthD}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Pagination Settings -->
                <GroupBox Header="分页设置" Margin="0,0,0,8">
                    <StackPanel>
                        <CheckBox Content="启用自动分页"
                                  IsChecked="{Binding AutoPagination}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  Margin="0,4"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,0"
                                    IsEnabled="{Binding AutoPagination}">
                            <Label Content="每页行数:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding RowsPerPage}"
                                     Width="80"
                                     IsEnabled="{Binding AutoPagination}"
                                     ToolTip="每页最大行数"/>
                        </StackPanel>

                        <!-- Page Preview -->
                        <Border Background="{DynamicResource ControlBackground}"
                                CornerRadius="4"
                                Padding="12"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="分页预览"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontSize="{DynamicResource SmallFontSize}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="总 "
                                               Foreground="{DynamicResource SecondaryText}"/>
                                    <TextBlock Text="{Binding Items.Count}"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontWeight="Bold"/>
                                    <TextBlock Text=" 项，分 "
                                               Foreground="{DynamicResource SecondaryText}"/>
                                    <TextBlock Text="{Binding EstimatedPages}"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontWeight="Bold"/>
                                    <TextBlock Text=" 页"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Insertion Point -->
                <GroupBox Header="插入点" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource InputBackground}"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,4,8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="当前插入点"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontSize="{DynamicResource SmallFontSize}"/>
                                <TextBlock Text="{Binding InsertionPointText}"
                                           Foreground="{DynamicResource PrimaryText}"
                                           FontWeight="SemiBold"
                                           FontSize="{DynamicResource LargeFontSize}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="1"
                                Content="拾取"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding PickPointCommand}"
                                Width="70"
                                Height="50"
                                VerticalAlignment="Center"
                                Margin="0,4"
                                ToolTip="在 CAD 图纸中拾取表格插入点"/>
                    </Grid>
                </GroupBox>

                <!-- Text Style -->
                <GroupBox Header="文字样式" Margin="0,0,0,8">
                    <StackPanel>
                        <Label Content="文字样式"/>
                        <ComboBox ItemsSource="{Binding TextStyles}"
                                  SelectedItem="{Binding SelectedTextStyle}"
                                  ToolTip="AutoCAD 文字样式"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Generate Button -->
        <Button Grid.Row="2"
                Content="生成表格"
                Style="{DynamicResource PrimaryButtonStyle}"
                Command="{Binding GenerateTableCommand}"
                HorizontalAlignment="Stretch"
                Height="40"
                FontSize="{DynamicResource LargeFontSize}"
                Margin="0,8,0,0"/>

        <!-- Hint -->
        <Border Grid.Row="3"
                Background="{DynamicResource InfoBrush}"
                Opacity="0.1"
                CornerRadius="4"
                Padding="8,6"
                Margin="0,8,0,0">
            <TextBlock Text="提示：拾取插入点后，点击「生成表格」在 CAD 中插入目录表"
                       Foreground="{DynamicResource InfoBrush}"
                       FontSize="{DynamicResource SmallFontSize}"/>
        </Border>

    </Grid>
</UserControl>
